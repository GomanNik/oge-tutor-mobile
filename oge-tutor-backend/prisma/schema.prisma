generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  teacher
  student
}

enum AccessTokenType {
  invite
  password_reset
}

enum AccessStatus {
  active
  invite_sent
  password_pending
  disabled
}

enum LessonStatus {
  planned
  rescheduled
  completed
  canceled
}

enum LessonSource {
  manual
  template
  import
}

enum HomeworkStatus {
  assigned
  submitted
  needs_revision
  reviewed
  overdue
}

enum SubmissionStatus {
  submitted
  reviewed
  needs_revision
}

enum FileScope {
  private_upload
  private_submission
  teacher_material
  shared_material
}

enum MaterialType {
  file
  link
  library
}

enum MaterialSource {
  upload
  link
  library
}

enum ProgressCoverageStatus {
  not_started
  in_progress
  assessment_needed
  assessed
}

enum ProgressMasteryLevel {
  weak
  medium
  good
  strong
}

enum ProgressSource {
  manual
  lesson_completed
  homework_result
  diagnostic
  import
}

enum NotificationType {
  progress_assessment_required
}

enum NotificationStatus {
  unread
  read
  resolved
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  role           Role
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  teacherProfile TeacherProfile?
  studentProfile StudentProfile?
  uploadedFiles  FileResource[]
  accessTokens   AccessToken[]

  @@index([role])
}

model AccessToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AccessTokenType
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, type])
  @@index([type, expiresAt])
  @@index([expiresAt])
  @@index([usedAt])
}

model TeacherProfile {
  id        String           @id @default(cuid())
  userId    String           @unique
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  avatar    String           @default("")
  bg        String           @default("")
  settings  Json             @default("{}")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  students  StudentProfile[]
  lessons   Lesson[]
  homeworks Homework[]
  topics    MaterialTopic[]
  notices   Notification[]
}

model StudentProfile {
  id             String                @id @default(cuid())
  userId         String                @unique
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  teacherId      String
  teacher        TeacherProfile        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  name           String
  grade          String                @default("")
  goal           String                @default("")
  avatar         String                @default("")
  bg             String                @default("")
  note           String                @default("")
  access         AccessStatus          @default(password_pending)
  settings       Json                  @default("{}")
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  lessons        Lesson[]
  homeworks      Homework[]
  progress       StudentTaskProgress[]
  historyEvents  ProgressHistory[]
  submissions    HomeworkSubmission[]
  notifications  Notification[]

  @@index([teacherId])
  @@index([teacherId, access])
  @@index([access])
}

model Lesson {
  id                String         @id @default(cuid())
  teacherId         String
  teacher           TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId         String
  student           StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  topic             String
  focusTaskNumbers  Int[]          @default([])
  startAt           DateTime
  endAt             DateTime
  timezone          String
  durationMinutes   Int
  status            LessonStatus   @default(planned)
  source            LessonSource   @default(manual)
  completedAt       DateTime?
  completionComment String         @default("")
  note              String         @default("")
  materials         Json           @default("[]")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  progressEvents    ProgressHistory[]
  notifications     Notification[]

  @@index([teacherId])
  @@index([studentId])
  @@index([startAt])
  @@index([teacherId, status, startAt])
  @@index([studentId, status, startAt])
}

model Homework {
  id              String               @id @default(cuid())
  teacherId       String
  teacher         TeacherProfile       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId       String
  student         StudentProfile       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title           String
  description     String               @default("")
  topic           String               @default("")
  taskNumbers     Int[]                @default([])
  dueAt           DateTime
  assignedAt      DateTime             @default(now())
  submittedAt     DateTime?
  reviewedAt      DateTime?
  closedAt        DateTime?
  status          HomeworkStatus       @default(assigned)
  materials       Json                 @default("[]")
  reviewMaterials Json                 @default("[]")
  solutionFile    String               @default("")
  teacherComment  String               @default("")
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  attempts        HomeworkSubmission[]

  @@index([teacherId])
  @@index([studentId])
  @@index([dueAt])
  @@index([teacherId, status, dueAt])
  @@index([studentId, status, dueAt])
}

model HomeworkSubmission {
  id             String         @id @default(cuid())
  homeworkId     String
  homework       Homework       @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentId      String
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileResourceId String
  fileResource   FileResource   @relation(fields: [fileResourceId], references: [id], onDelete: Restrict)
  reviewStatus   SubmissionStatus @default(submitted)
  submittedAt    DateTime       @default(now())
  reviewedAt     DateTime?
  teacherComment String         @default("")

  @@index([homeworkId])
  @@index([studentId])
  @@index([fileResourceId])
}

model FileResource {
  id          String               @id @default(cuid())
  ownerId     String
  owner       User                 @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  scope       FileScope            @default(private_upload)
  originalName String
  mimeType    String
  size        Int
  url         String
  storagePath String
  uploadedAt DateTime             @default(now())
  submissions HomeworkSubmission[]
  attachments MaterialAttachment[]

  @@index([ownerId])
  @@index([scope])
  @@index([uploadedAt])
}

model MaterialTopic {
  id         String               @id @default(cuid())
  teacherId  String
  teacher    TeacherProfile       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  taskNumber Int
  title      String
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  files      MaterialAttachment[]

  @@unique([teacherId, taskNumber])
  @@index([teacherId])
}

model MaterialAttachment {
  id          String         @id @default(cuid())
  topicId     String
  topic       MaterialTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  type        MaterialType
  source      MaterialSource
  title       String
  url         String         @default("")
  fileId      String?
  file        FileResource?  @relation(fields: [fileId], references: [id], onDelete: SetNull)
  originalName String        @default("")
  fileName    String         @default("")
  mimeType    String         @default("")
  size        Int            @default(0)
  uploadedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([topicId])
  @@index([fileId])
}

model StudentTaskProgress {
  id                       String            @id @default(cuid())
  studentId                String
  student                  StudentProfile    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taskNumber               Int
  coverageStatus           ProgressCoverageStatus @default(not_started)
  masteryLevel             ProgressMasteryLevel?
  lastAssessedMasteryLevel ProgressMasteryLevel?
  lessonCount              Int               @default(0)
  lastLessonId             String?
  lastActivityAt           DateTime?
  lastAssessedAt           DateTime?
  source                   ProgressSource    @default(manual)
  teacherComment           String            @default("")
  recommendedAction        String            @default("")
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  history                  ProgressHistory[]

  @@unique([studentId, taskNumber])
  @@index([studentId])
}

model ProgressHistory {
  id             String              @id @default(cuid())
  studentId      String
  student        StudentProfile      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taskProgressId String?
  taskProgress   StudentTaskProgress? @relation(fields: [taskProgressId], references: [id], onDelete: SetNull)
  taskNumber     Int
  lessonId       String?
  lesson         Lesson?             @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  type           String
  source         ProgressSource
  coverageStatus ProgressCoverageStatus
  masteryLevel   ProgressMasteryLevel?
  comment        String              @default("")
  createdAt      DateTime            @default(now())

  @@index([studentId])
  @@index([studentId, createdAt])
  @@index([taskProgressId])
  @@index([lessonId])
}

model Notification {
  id         String          @id @default(cuid())
  type       NotificationType
  status     NotificationStatus @default(unread)
  teacherId  String
  teacher    TeacherProfile  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentId  String?
  student    StudentProfile? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  taskNumber Int?
  lessonId   String?
  lesson     Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  title      String
  message    String
  createdAt  DateTime        @default(now())
  resolvedAt DateTime?

  @@index([teacherId])
  @@index([studentId])
  @@index([teacherId, status])
  @@index([studentId, status])
  @@index([lessonId])
}
