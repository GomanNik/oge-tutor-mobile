{
  "name": "oge-tutor-app-v2",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "backend:generate": "pnpm --dir oge-tutor-backend run prisma:generate",
    "backend:build": "pnpm --dir oge-tutor-backend run build",
    "backend:lint": "pnpm --dir oge-tutor-backend run lint",
    "backend:test": "pnpm --dir oge-tutor-backend test",
    "frontend:build": "pnpm --dir oge-tutor-app run build",
    "frontend:lint": "pnpm --dir oge-tutor-app run lint",
    "frontend:typecheck": "pnpm --dir oge-tutor-app run typecheck",
    "frontend:test": "pnpm --dir oge-tutor-app test",
    "quality": "pnpm run backend:generate && pnpm run backend:build && pnpm run backend:lint && pnpm run backend:test && pnpm run frontend:build && pnpm run frontend:lint && pnpm run frontend:typecheck && pnpm run frontend:test"
  },
  "pnpm": {
    "overrides": {
      "multer": "2.2.0",
      "express>path-to-regexp": "0.1.13",
      "qs": "6.15.3",
      "@nestjs/cli>glob": "10.5.0",
      "@angular-devkit/core>picomatch": "4.0.4",
      "@angular-devkit/core>ajv": "8.18.0",
      "@babel/core": "7.29.7",
      "js-yaml": "4.2.0",
      "lodash": "4.18.1",
      "effect": "3.21.4",
      "vite": "8.1.3",
      "ws": "8.21.0",
      "tmp": "0.2.7"
    }
  }
}
